{
  "statusLine": {
    "type": "command",
    "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/statusline.py"
  },
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(cd android && ./gradlew *)",
      "Bash(cd backend && ./gradlew *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)"
    ],
    "deny": [
      "Read(**/local.properties)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/google-services.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/block-secrets.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-format.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/filter-gradle-output.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "rag-evaluator",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p $CLAUDE_PROJECT_DIR/specs/eval && echo \"[$(date -u +%Y-%m-%dT%H:%M:%SZ)] eval executado\" >> $CLAUDE_PROJECT_DIR/specs/eval/history.md"
          }
        ]
      }
    ]
  }
}
